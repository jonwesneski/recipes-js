{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": [
        "^@repo/database#build",
        "^@repo/zod-schemas#build",
        "^@repo/nest-shared#build"
      ],
      "outputs": ["dist/**"],
      "passThroughEnv": [
        "SWAGGER_ONLY",
        "JWT_SECRET",
        "REFRESH_JWT_SECRET",
        "REFRESH_JWT_EXPIRE_IN",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_SECRET",
        "GOOGLE_CALLBACK_URL"
      ]
    },
    "swagger:only": {
      "dependsOn": [
        "^@repo/database#build",
        "^@repo/zod-schemas#build",
        "^@repo/nest-shared#build"
      ],
      "outputs": ["swagger.json"]
    },
    "ci:lint": {
      "dependsOn": ["^@repo/nest-shared#build"]
    }
  }
}
